CREATE TABLE Genres (
    Id INTEGER PRIMARY KEY AUTOINCREMENT,
    Name TEXT NOT NULL UNIQUE
);


CREATE TABLE Books (
    Id INTEGER PRIMARY KEY AUTOINCREMENT,
    Title TEXT NOT NULL,
    Author TEXT,
    Price REAL,
    GenreId INTEGER,

    FOREIGN KEY (GenreId) REFERENCES Genres(Id) ON DELETE SET NULL
);


